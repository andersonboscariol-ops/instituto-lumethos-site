<script>
// Forçar header escuro permanentemente - desativa troca de classes do tema
(function() {
  // Observer que mantém as classes corretas no header
  const observer = new MutationObserver(function(mutations) {
    const header = document.querySelector('header');
    if (!header) return;
    
    // Sempre manter header--secondary, remover header--primary se aparecer
    if (header.classList.contains('header--primary')) {
      header.classList.remove('header--primary');
    }
    if (!header.classList.contains('header--secondary')) {
      header.classList.add('header--secondary');
    }
    
    // Forçar estilos inline de fundo escuro
    header.style.backgroundColor = '';
    header.style.background = '';
    
    // Forçar logo light visível
    document.querySelectorAll('.header-inner__logo--light').forEach(el => {
      el.style.opacity = '1';
      el.style.display = 'block';
    });
    document.querySelectorAll('.header-inner__logo--dark').forEach(el => {
      el.style.opacity = '0';
      el.style.display = 'none';
    });
    
    // Links da navbar sempre brancos
    document.querySelectorAll('.menu__link').forEach(el => {
      el.style.color = '#fff';
    });
  });
  
  // Observar o header e o body para mudanças de classe
  observer.observe(document.documentElement, { 
    attributes: true, 
    attributeFilter: ['class'],
    subtree: true
  });
  
  // Também observar especificamente o header
  const headerObserver = new MutationObserver(function() {
    const header = document.querySelector('header');
    if (header) {
      header.style.backgroundColor = '';
      header.style.background = '';
    }
  });
  
  if (document.querySelector('header')) {
    headerObserver.observe(document.querySelector('header'), {
      attributes: true,
      attributeFilter: ['class', 'style']
    });
  }
  
  // Fechar nav-drop ao clicar em qualquer link do menu
  document.addEventListener('click', function(e) {
    const link = e.target.closest('.menu__link, .nav-drop a');
    if (link) {
      document.body.classList.remove('nav-active');
      const header = document.querySelector('header');
      if (header && header.classList.contains('header--primary')) {
        header.classList.remove('header--primary');
      }
      if (header && !header.classList.contains('header--secondary')) {
        header.classList.add('header--secondary');
      }
    }
  });
  
  // Rodar após carregamento completo
  window.addEventListener('load', function() {
    const header = document.querySelector('header');
    if (header) {
      // Garantir que header é header--secondary
      if (header.classList.contains('header--primary')) {
        header.classList.remove('header--primary');
      }
      if (!header.classList.contains('header--secondary')) {
        header.classList.add('header--secondary');
      }
      header.style.backgroundColor = '';
      header.style.background = '';
    }
    
    // Garantir links brancos
    document.querySelectorAll('.menu__link').forEach(el => {
      el.style.color = '#fff';
    });
    
    // Logo light visível
    document.querySelectorAll('.header-inner__logo--light').forEach(el => {
      el.style.opacity = '1';
      el.style.display = 'block';
    });
  });
})();
</script>

