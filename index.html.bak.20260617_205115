<script>
// Hover effect for SVG icons - switch between mono and colorful
document.querySelectorAll('[style*="border-radius:12px"], [style*="background:linear-gradient"]').forEach(card => {
  const svg = card.querySelector('.s-icon');
  if (!svg) return;
  
  // Store mono version
  const monoHTML = svg.outerHTML;
  
  // Load colorful version
  card.addEventListener('mouseenter', () => {
    // We'll use a class approach - just add a color-enable class
    card.classList.add('icon-hover');
  });
  card.addEventListener('mouseleave', () => {
    card.classList.remove('icon-hover');
  });
});
</script>
<style>
.icon-hover .s-icon { color: #C79A2E !important; }
.icon-hover .s-icon .s-icon-path { stroke: currentColor; }
[style*="border-radius:12px"]:hover,
[style*="background:linear-gradient"]:hover { border-color: rgba(199,154,46,0.4) !important; transform: translateY(-2px); }
</style>


<style>
.icon-card { transition: all 0.3s ease; position: relative; }
.icon-card:hover { border-color: rgba(199,154,46,0.4) !important; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(199,154,46,0.08); }
.icon-card:hover .s-icon { filter: drop-shadow(0 0 6px rgba(199,154,46,0.15)); }
</style>


<style>
.icon-svg { color: #C79A2E; transition: all 0.3s ease; }
.icon-svg:hover { color: #E8B84B; filter: drop-shadow(0 0 8px rgba(199,154,46,0.2)); }
.s-icon { color: #C79A2E; transition: all 0.3s ease; }
.icon-card:hover .s-icon { color: #E8B84B; filter: drop-shadow(0 0 8px rgba(199,154,46,0.2)); }
.icon-card:hover { border-color: rgba(199,154,46,0.4) !important; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(199,154,46,0.08); }
