<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Instituto Lumethos</title>
  <meta name="description" content="Área do Aluno Instituto Lumethos — seus cursos e progresso.">
  <link rel="icon" type="image/x-icon" href="img/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/area-do-aluno.css">
  <style>
    .aluno-dashboard {
      padding-top: 88px;
      max-width: 1280px;
      margin: 0 auto;
      padding-left: 24px;
      padding-right: 24px;
      padding-bottom: 60px;
    }
    .boas-vindas {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 32px;
      flex-wrap: wrap;
      gap: 16px;
    }
    .boas-vindas h1 {
      font-size: 28px;
    }
    .boas-vindas h1 span {
      color: var(--gold);
    }
    .boas-vindas p {
      color: var(--text-secondary);
      font-size: 14px;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border-card);
      border-radius: var(--radius-md);
      padding: 20px;
      text-align: center;
    }
    .stat-card .num {
      font-size: 32px;
      font-weight: 700;
      color: var(--gold);
      font-family: 'Libre Baskerville', serif;
    }
    .stat-card .label {
      font-size: 12px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 4px;
    }

    @media (max-width: 768px) {
      .aluno-dashboard { padding-left: 12px; padding-right: 12px; padding-top: 76px; }
      .boas-vindas h1 { font-size: 22px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

  <!-- Header -->
  <header class="header-aluno" id="header">
    <div class="logo">
      <img src="img/logo-lumethos-correto.png" alt="Lumethos">
      <span>Aluno</span>
    </div>
    <nav>
      <a href="aluno.html" class="active">Dashboard</a>
      <a href="biblioteca.html">Biblioteca</a>
      <a href="index.html">Site</a>
    </nav>
    <div class="user-menu" id="userMenu" onclick="toggleDropdown(event)">
      <div class="user-avatar" id="userAvatar">A</div>
      <span class="user-name" id="userName">Aluno</span>
      <button class="btn-sair" onclick="fazerLogout(event)">Sair</button>
    </div>
  </header>

  <!-- Main -->
  <main class="aluno-dashboard">

    <!-- Boas-vindas -->
    <div class="boas-vindas">
      <div>
        <h1>Olá, <span id="nomeAluno">Aluno</span> 👋</h1>
        <p>Continue seus estudos de onde parou</p>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid" id="statsGrid">
      <div class="stat-card">
        <div class="num" id="totalCursos">0</div>
        <div class="label">Cursos</div>
      </div>
      <div class="stat-card">
        <div class="num" id="totalConcluidos">0</div>
        <div class="label">Concluídos</div>
      </div>
      <div class="stat-card">
        <div class="num" id="progressoGeral">0%</div>
        <div class="label">Progresso Geral</div>
      </div>
      <div class="stat-card">
        <div class="num" id="modulosConcluidos">0</div>
        <div class="label">Módulos</div>
      </div>
    </div>

    <!-- Entregas Pendentes -->
    <div class="section-title" style="margin-top:32px;">
      <span>📤 Minhas Entregas</span>
    </div>
    <div class="curso-card" style="padding: 20px; margin-bottom: 24px;" id="entregasPendentes">
      <div style="text-align:center;padding:20px;color:var(--text-muted)">
        <div class="spinner"></div>
        <p style="font-size:13px;margin-top:8px">Carregando entregas...</p>
      </div>
    </div>

    <!-- Filtros -->
    <div class="section-title">
      <span>Meus Cursos</span>
      <span class="count" id="cursosCount"></span>
    </div>
    <div class="filtro-categorias" id="filtroCategorias">
      <button class="btn-categoria active" data-cat="all">Todos</button>
    </div>

    <!-- Cursos Grid -->
    <div class="cursos-grid" id="cursosGrid">
      <!-- Renderizado via JS -->
    </div>

  </main>

  <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
  <script src="api/config.js"></script>
  <script src="api/cursos.js"></script>
  <script>
    // ============================================================
    // DASHBOARD — Área do Aluno
    // ============================================================

    const API = window.API;
const token = localStorage.getItem('lms_token');
const user = JSON.parse(localStorage.getItem('lms_user') || '{}');

if (!token || !user.id) {
  window.location.href = '/admin/login.html';
}

// Elementos DOM
const userName = document.getElementById('userName');
const userBadge = document.getElementById('userBadge');
const cursosGrid = document.getElementById('cursosGrid');
const submissionsList = document.getElementById('submissionsList');
const notificationsList = document.getElementById('notificationsList');
const filtroCategorias = document.getElementById('filtroCategorias');
const totalCursos = document.getElementById('totalCursos');
const totalConcluidos = document.getElementById('totalConcluidos');
const progressoGeral = document.getElementById('progressoGeral');
const modulosConcluidos = document.getElementById('modulosConcluidos');
const progressContainer = document.getElementById('progressContainer');

// Inicialização
userName.textContent = user.nome || user.email;
userBadge.textContent = user.nome ? user.nome.charAt(0).toUpperCase() : 'A';

// Stats
let statsCursos = 0, statsConcluidos = 0, statsProgresso = 0, statsModulos = 0;

// Carregar Cursos
async function loadCursos() {
  try {
    cursosGrid.innerHTML = '<div class="loading-spinner"><div class="spinner"></div><p>Carregando cursos...</p></div>';
    const cursos = await API.getCursos();
    
    if (!cursos || cursos.length === 0) {
      cursosGrid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><div class="icon">📚</div><h3>Nenhum curso encontrado</h3><p>Em breve novos cursos serão disponibilizados.</p></div>';
      totalCursos.textContent = '0';
      return;
    }
    
    totalCursos.textContent = cursos.length;
    statsCursos = cursos.length;
    cursosGrid.innerHTML = '';
    
    for (const curso of cursos) {
      const progresso = await API.getProgresso(curso.id).catch(() => ({ total: 0, concluidas: 0 }));
      const perc = progresso.total > 0 ? Math.round((progresso.concluidas / progresso.total) * 100) : 0;
      
      const card = document.createElement('div');
      card.className = 'curso-card';
      card.style.cursor = 'pointer';
      card.onclick = () => { window.location.href = '/aluno/curso.html?id=' + curso.id; };
      card.innerHTML = 
        '<div class="card-img" style="background: ' + (curso.cor || '#0D1B2A') + '">' +
          '<img src="" alt="" style="display:none">' +
        '</div>' +
        '<div class="card-body">' +
          '<div class="card-categoria">Capelania</div>' +
          '<div class="card-title">' + curso.titulo + '</div>' +
          '<div class="card-desc">' + (curso.descricao || '').substring(0, 80) + '</div>' +
          '<div class="card-meta">' + progresso.total + ' aulas</div>' +
          '<div class="progress-bar-container">' +
            '<div class="progress-bar"><div class="progress-bar-fill" style="width:' + perc + '%"></div></div>' +
            '<div class="progress-text">' + (perc > 0 ? perc + '%' : 'Não iniciado') + '</div>' +
          '</div>' +
        '</div>';
      cursosGrid.appendChild(card);
    }
  } catch (err) {
    console.error('Erro cursos:', err);
    cursosGrid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><div class="icon">⚠️</div><h3>Erro ao carregar</h3><p>' + err.message + '</p></div>';
  }
}

// Carregar Entregas
async function loadEntregas() {
  try {
    const entregas = await API.getEntregas().catch(() => []);
    if (!entregas || entregas.length === 0) {
      submissionsList.innerHTML = '<div class="empty-state"><div class="icon">📝</div><h3>Nenhuma entrega pendente</h3><p>Todas em dia!</p></div>';
      return;
    }
    submissionsList.innerHTML = entregas.map(e => 
      '<div class="submission-item"><div class="submission-status ' + (e.status || 'pendente') + '"></div>' +
      '<div class="submission-info"><strong>' + (e.titulo || 'Entrega') + '</strong><span>' + (e.data_entrega || '') + '</span></div>' +
      (e.nota ? '<div class="submission-grade">' + e.nota + '</div>' : '') + '</div>'
    ).join('');
  } catch (err) {
    submissionsList.innerHTML = '<div class="empty-state"><div class="icon">📝</div><h3>Indisponível</h3></div>';
  }
}

// Notificações
function loadNotificacoes() {
  notificationsList.innerHTML = 
    '<div class="notification-item"><div class="notif-icon">📢</div><div class="notif-content"><strong>Bem-vindo ao Instituto Lumethos!</strong><p>Explore seus cursos e comece sua jornada.</p></div></div>';
}

// Logout
document.getElementById('logoutBtn').addEventListener('click', () => {
  API.logout();
  window.location.href = '/admin/login.html';
});

// Iniciar
loadCursos();
loadEntregas();
loadNotificacoes();
</script>
  <script src="/js/juju-chat.js"></script>
</body>
</html>
