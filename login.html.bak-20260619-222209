<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Área do Aluno · Instituto Lumethos</title>
  <link rel="icon" href="/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    html, body {
      height: 100%;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ═══════════════════════════
       SPLIT LAYOUT
       ═══════════════════════════ */
    .split {
      display: flex;
      min-height: 100vh;
      width: 100%;
    }

    /* ═══════════════════════════
       LEFT PANEL — Branding (65%)
       ═══════════════════════════ */
    .left-panel {
      flex: 0 0 62%;
      background: #0a1628;
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 90px;
      position: relative;
      overflow: hidden;
    }
    .left-panel::before {
      content: '';
      position: absolute;
      inset: 0;
      background: 
        radial-gradient(ellipse at 30% 20%, rgba(196,149,58,0.06) 0%, transparent 60%),
        radial-gradient(ellipse at 70% 80%, rgba(196,149,58,0.04) 0%, transparent 50%);
      pointer-events: none;
    }

    .left-inner {
      position: relative;
      z-index: 1;
      max-width: 520px;
    }

    /* Tagline badge */
    .tagline-badge {
      display: inline-block;
      padding: 8px 24px;
      background: rgba(196,149,58,0.12);
      border: 1px solid rgba(196,149,58,0.25);
      color: #d4a843;
      border-radius: 50px;
      font-family: 'Cinzel', serif;
      font-size: 10.5px;
      font-weight: 500;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      margin-bottom: 40px;
    }

    /* Logo */
    .brand-logo {
      margin-bottom: 48px;
    }
    .brand-logo img {
      height: 96px;
      width: auto;
    }

    /* Title */
    .left-title {
      font-family: 'Inter', sans-serif;
      font-size: 36px;
      font-weight: 800;
      color: #f1f5f9;
      margin-bottom: 16px;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }
    .left-desc {
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      font-weight: 400;
      color: rgba(241,245,249,0.55);
      line-height: 1.75;
      max-width: 440px;
    }

    /* ═══════════════════════════
       RIGHT PANEL — Login Form (35%)
       ═══════════════════════════ */
    .right-panel {
      flex: 1;
      background: #ffffff;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 64px;
    }

    .right-inner {
      max-width: 400px;
      width: 100%;
    }

    .welcome-title {
      font-size: 28px;
      font-weight: 800;
      color: #1a1a2e;
      margin-bottom: 4px;
      letter-spacing: -0.02em;
    }
    .welcome-sub {
      font-size: 15px;
      color: #6b7280;
      margin-bottom: 36px;
      font-weight: 400;
    }

    /* Form elements */
    .form-group {
      margin-bottom: 20px;
    }
    .form-label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: #4b5563;
      margin-bottom: 6px;
    }
    .form-input {
      width: 100%;
      padding: 13px 16px;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      color: #111827;
      font-size: 15px;
      font-family: 'Inter', system-ui, sans-serif;
      transition: all 0.2s ease;
      outline: none;
    }
    .form-input::placeholder {
      color: #9ca3af;
    }
    .form-input:focus {
      border-color: #c4953a;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(196,149,58,0.1);
    }
    .form-input.error-input {
      border-color: #ef4444;
      background: #fef2f2;
    }

    /* Checkbox row */
    .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
    }
    .remember-row {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }
    .remember-row input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 18px;
      height: 18px;
      border: 1.5px solid #d1d5db;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.15s ease;
      position: relative;
      flex-shrink: 0;
    }
    .remember-row input[type="checkbox"]:checked {
      background: #c4953a;
      border-color: #c4953a;
    }
    .remember-row input[type="checkbox"]:checked::after {
      content: '✓';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%,-50%);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
    }
    .remember-label {
      font-size: 13px;
      color: #4b5563;
      user-select: none;
    }
    .forgot-link {
      font-size: 13px;
      color: #6b7280;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.15s ease;
    }
    .forgot-link:hover {
      color: #c4953a;
    }

    /* Button */
    .btn-login {
      width: 100%;
      padding: 14px;
      background: #c4953a;
      color: #fff;
      border: none;
      border-radius: 14px;
      font-size: 15px;
      font-weight: 700;
      font-family: 'Inter', system-ui, sans-serif;
      cursor: pointer;
      transition: all 0.2s ease;
      letter-spacing: 0.01em;
    }
    .btn-login:hover {
      background: #b8892f;
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(196,149,58,0.3);
    }
    .btn-login:active {
      transform: translateY(0);
    }
    .btn-login:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    /* Signup link */
    .signup-row {
      text-align: center;
      margin-top: 28px;
    }
    .signup-text {
      font-size: 14px;
      color: #6b7280;
    }
    .signup-link {
      color: #c4953a;
      font-weight: 600;
      text-decoration: none;
      transition: color 0.15s ease;
    }
    .signup-link:hover {
      color: #b8892f;
    }

    /* Alerts */
    .alert {
      padding: 11px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 16px;
      display: none;
    }
    .alert.error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
    }
    .alert.success {
      background: #ecfdf5;
      border: 1px solid #a7f3d0;
      color: #059669;
    }
    .alert.info {
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      color: #2563eb;
    }

    /* Spinner */
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.4);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.5s linear infinite;
      vertical-align: middle;
      margin-right: 6px;
    }

    /* ═══════════════════════════
       RESPONSIVE
       ═══════════════════════════ */
    @media (max-width: 900px) {
      .split {
        flex-direction: column;
      }
      .left-panel {
        flex: 0 0 auto;
        padding: 48px 32px 32px;
        min-height: auto;
      }
      .left-inner {
        text-align: center;
        margin: 0 auto;
      }
      .brand-row {
        justify-content: center;
      }
      .brand-logo img {
        height: 150px;
      }
      .tagline-badge {
        margin-bottom: 20px;
      }
      .brand-logo {
        margin-bottom: 24px;
      }
      .left-title {
        text-align: center;
        font-size: 26px;
        margin-bottom: 8px;
      }
      .left-desc {
        text-align: center;
        max-width: 100%;
        font-size: 13px;
      }
      .right-panel {
        padding: 32px 24px 48px;
      }
      .welcome-title {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <div class="split">
    <!-- ═══ LEFT: BRANDING ═══ -->
    <div class="left-panel">
      <div class="left-inner">
        <div class="tagline-badge">SAPIENTIA AD MINISTERIUM</div>

        <div class="brand-logo">
          <img src="/img/logo-lumethos-correto.png" alt="Instituto Lumethos" onerror="this.style.display='none'">
        </div>

        <h1 class="left-title">Área do Aluno</h1>
        <p class="left-desc">
          Acesse seus cursos, materiais exclusivos e ferramentas ministeriais. 
          Sua jornada de capacitação teológica continua aqui.
        </p>
      </div>
    </div>

    <!-- ═══ RIGHT: LOGIN ═══ -->
    <div class="right-panel">
      <div class="right-inner">
        <h2 class="welcome-title">Bem-vindo de volta</h2>
        <p class="welcome-sub">Faça login para acessar sua conta</p>

        <!-- Alerts -->
        <div class="alert error" id="loginError"></div>
        <div class="alert success" id="loginSuccess"></div>
        <div class="alert info" id="loginInfo"></div>

        <!-- Form -->
        <form id="loginForm" onsubmit="handleLogin(event)">
          <div class="form-group">
            <label class="form-label" for="email">E-mail</label>
            <input type="email" id="email" class="form-input" placeholder="seu@email.com" required autofocus>
          </div>

          <div class="form-group" style="position:relative;">
            <label class="form-label" for="password">Senha</label>
            <input type="password" id="password" class="form-input" placeholder="••••••••" required style="padding-right:44px;">
            <button type="button" id="togglePwd" aria-label="Mostrar senha" style="position:absolute;right:12px;bottom:12px;background:none;border:none;cursor:pointer;padding:0;color:#9ca3af;display:flex;align-items:center;justify-content:center;width:22px;height:22px;transition:color .2s;" onmouseover="this.style.color='#c4953a'" onmouseout="this.style.color='#9ca3af'">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>

          <div class="row">
            <label class="remember-row">
              <input type="checkbox" id="rememberMe">
              <span class="remember-label">Lembrar-me</span>
            </label>
            <a href="#" onclick="showForgotPassword(event)" class="forgot-link">Esqueci a senha</a>
          </div>

          <button type="submit" class="btn-login" id="loginBtn">
            Entrar
          </button>
        </form>

        <div class="signup-row">
          <span class="signup-text">Ainda não tem conta? </span>
          <a href="https://institutolumethos.online" class="signup-link">Cadastre-se</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    var API = '/api';

    // Auto-redirect if already logged in
    (async function(){
      var t = localStorage.getItem('lumethos_token');
      if (!t) return;
      try {
        var r = await fetch(API+'/auth/me',{headers:{'Authorization':'***'+t}});
        if (r.ok) {
          var d = await r.json();
          if (d.user) window.location.href = getRedirect();
        }
      } catch(e) {}
    })();

    function getRedirect(){
      var p = new URLSearchParams(window.location.search).get('redirect');
      return p || '/aluno/dashboard.html';
    }

    function hideAlerts() {
      ['loginError','loginSuccess','loginInfo'].forEach(function(id){
        var el = document.getElementById(id);
        if (el) el.style.display = 'none';
      });
    }

    function showAlert(type, msg) {
      hideAlerts();
      var id = 'login' + (type==='error'?'Error':type==='success'?'Success':'Info');
      var el = document.getElementById(id);
      if (el) { el.textContent = msg; el.style.display = 'block'; }
    }

    async function handleLogin(e) {
      e.preventDefault();
      var email = document.getElementById('email').value.trim();
      var password = document.getElementById('password').value;
      var btn = document.getElementById('loginBtn');

      hideAlerts();
      if (!email || !password) {
        showAlert('error','Preencha e-mail e senha.');
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span> Entrando...';

      try {
        var r = await fetch(API+'/auth/login', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({email:email,password:password})
        });
        var d = await r.json();

        if (!r.ok || d.error) {
          var msg = d.error || 'Erro ao fazer login.';
          if (msg === 'Email ou senha incorretos') msg = 'E-mail ou senha incorretos. Verifique os dados.';
          showAlert('error',msg);
          btn.disabled = false;
          btn.textContent = 'Entrar';
          return;
        }

        if (d.token && d.user) {
          localStorage.setItem('lumethos_token', d.token);
          localStorage.setItem('lumethos_user', JSON.stringify(d.user));
          showAlert('success','Login realizado! Redirecionando...');
          btn.innerHTML = '✓ Conectado';
          setTimeout(function(){
            window.location.href = getRedirect();
          }, 400);
        }
      } catch(err) {
        showAlert('error','Erro de conexão. Tente novamente.');
        btn.disabled = false;
        btn.textContent = 'Entrar';
      }
    }

    async function showForgotPassword(e) {
      e.preventDefault();
      var email = document.getElementById('email').value.trim();
      if (!email) { email = prompt('Digite seu e-mail para recuperação:'); }
      if (!email) return;

      hideAlerts();
      showAlert('info','Enviando link de recuperação...');

      try {
        var r = await fetch(API+'/auth/forgot-password', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({email:email})
        });
        var d = await r.json();
        if (!r.ok || d.error) {
          showAlert('error','Erro ao enviar. Verifique o e-mail informado.');
        } else {
          showAlert('success','Link de recuperação enviado! Verifique seu e-mail.');
        }
      } catch(err) {
        showAlert('error','Erro de conexão.');
      }
    }

    // Remember me
    (function(){
      var saved = localStorage.getItem('lumethos_remember');
      if (saved) {
        try {
          var data = JSON.parse(saved);
          document.getElementById('email').value = data.email || '';
          document.getElementById('rememberMe').checked = true;
        } catch(e) {}
      }
    })();

    document.getElementById('rememberMe').addEventListener('change', function(){
      if (this.checked) {
        var email = document.getElementById('email').value.trim();
        if (email) {
          localStorage.setItem('lumethos_remember', JSON.stringify({email:email}));
        }
      } else {
        localStorage.removeItem('lumethos_remember');
      }
    });

    document.getElementById('email').addEventListener('input', function(){
      if (document.getElementById('rememberMe').checked) {
        localStorage.setItem('lumethos_remember', JSON.stringify({email:this.value.trim()}));
      }
    });

    // Password visibility toggle
    (function(){
      var btn = document.getElementById('togglePwd');
      var pwd = document.getElementById('password');
      var eyeSvg = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
      var eyeOffSvg = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
      btn.addEventListener('click', function(){
        if (pwd.type === 'password') {
          pwd.type = 'text';
          btn.innerHTML = eyeOffSvg;
          btn.setAttribute('aria-label','Ocultar senha');
        } else {
          pwd.type = 'password';
          btn.innerHTML = eyeSvg;
          btn.setAttribute('aria-label','Mostrar senha');
        }
      });
    })();
  </script>
</body>
</html>
