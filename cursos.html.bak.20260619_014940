<script>
// DROPDOWN CURSOS - hover desktop, click mobile
(function(){
  var menu = document.getElementById('dd-menu');
  var link = menu && menu.previousElementSibling;
  if(!menu || !link) return;
  
  function isMobile(){ return window.innerWidth < 1024; }
  
  // Desktop: hover no li pai
  var li = menu.parentElement;
  li.addEventListener('mouseenter', function(){ if(!isMobile()) menu.style.display = 'block'; });
  li.addEventListener('mouseleave', function(){ if(!isMobile()) menu.style.display = 'none'; });
  
  // Mobile: clique
  link.addEventListener('click', function(e){
    if(isMobile()){
      e.preventDefault();
      menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
    }
  });
  
  // Fecha ao clicar fora
  document.addEventListener('click', function(e){
    if(!e.target.closest('li') || !e.target.closest('li').parentElement) return;
    if(isMobile() && menu.style.display === 'block' && !e.target.closest('#dd-menu') && e.target !== link && !link.contains(e.target)){
      menu.style.display = 'none';
    }
  });
  
  // Reset no resize
  window.addEventListener('resize', function(){
    if(!isMobile()) menu.style.display = 'none';
  });
})();
</script>
