<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Instituto Lumethos</title>
  <meta name="description" content="Painel Administrativo Instituto Lumethos">
  <link rel="icon" type="image/x-icon" href="../img/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Roboto', sans-serif;
      background: linear-gradient(135deg, #0D1B2A 0%, #142D4C 50%, #1a2a4a 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .login-wrapper {
      display: flex;
      max-width: 880px;
      width: 100%;
      min-height: 500px;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      background: #fff;
    }
    .login-left {
      flex: 1;
      background: linear-gradient(135deg, #0D1B2A 0%, #142D4C 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 50px 36px;
      color: #fff;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .login-left::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 30% 50%, rgba(199,154,46,0.08) 0%, transparent 60%);
      pointer-events: none;
    }
    .login-left .badge {
      display: inline-block;
      background: rgba(199,154,46,0.15);
      color: #C79A2E;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2.5px;
      padding: 6px 16px;
      border-radius: 20px;
      margin-bottom: 20px;
    }
    .login-left h1 {
      font-family: 'Libre Baskerville', serif;
      font-size: 22px;
      margin-bottom: 8px;
    }
    .login-left p {
      color: rgba(255,255,255,0.5);
      font-size: 13px;
      max-width: 240px;
      line-height: 1.6;
    }
    .login-right {
      flex: 1;
      padding: 50px 44px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: #fff;
    }
    .login-right h2 {
      font-family: 'Libre Baskerville', serif;
      color: #1a1a2e;
      font-size: 24px;
      margin-bottom: 4px;
    }
    .login-right .sub {
      color: #8888aa;
      font-size: 14px;
      margin-bottom: 28px;
    }
    .form-group {
      margin-bottom: 18px;
    }
    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #1a1a2e;
      margin-bottom: 6px;
    }
    .form-group input {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid #e0e0e0;
      border-radius: 10px;
      font-size: 14px;
      font-family: 'Roboto', sans-serif;
      transition: all 0.25s;
      background: #f8f9fa;
      color: #1a1a2e;
    }
    .form-group input:focus {
      outline: none;
      border-color: #C79A2E;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(199,154,46,0.1);
    }
    .form-group input.input-error {
      border-color: #dc2626;
      background: #fef2f2;
    }
    .btn-login {
      width: 100%;
      padding: 14px;
      background: #C79A2E;
      color: #0D1B2A;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
      font-family: 'Roboto', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 8px;
    }
    .btn-login:hover:not(:disabled) {
      background: #d4aa3a;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(199,154,46,0.3);
    }
    .btn-login:disabled { opacity: 0.7; cursor: not-allowed; }
    .btn-login .spinner {
      display: none;
      width: 18px; height: 18px;
      border: 2px solid rgba(13,27,42,0.3);
      border-top-color: #0D1B2A;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }
    .btn-login.loading .spinner { display: inline-block; }
    .btn-login.loading .btn-text { display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .login-error {
      display: none;
      background: #fef2f2;
      color: #b91c1c;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13px;
      margin-top: 14px;
      text-align: center;
      border: 1px solid #fecaca;
    }
    .login-error.show { display: block; }
    .login-footer {
      text-align: center;
      margin-top: 20px;
      font-size: 13px;
      color: #8888aa;
    }
    .login-footer a { color: #C79A2E; text-decoration: none; }
    .login-footer a:hover { text-decoration: underline; }
    .role-selector {
      display: flex;
      gap: 8px;
      margin-bottom: 18px;
    }
    .role-btn {
      flex: 1;
      padding: 10px;
      border: 1.5px solid #e0e0e0;
      border-radius: 8px;
      background: #f8f9fa;
      color: #4a4a6a;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      font-family: 'Roboto', sans-serif;
      transition: all 0.25s;
      text-align: center;
    }
    .role-btn:hover {
      border-color: #C79A2E;
      color: #C79A2E;
    }
    .role-btn.active {
      background: #C79A2E;
      color: #0D1B2A;
      border-color: #C79A2E;
    }
    @media (max-width: 700px) {
      .login-wrapper { flex-direction: column; min-height: auto; border-radius: 14px; }
      .login-left { padding: 36px 28px; }
      .login-left h1 { font-size: 18px; }
      .login-right { padding: 32px 24px; }
      .login-right h2 { font-size: 20px; }
    }
  </style>
</head>
<body>
  <div class="login-wrapper">
    <div class="login-left">
      <span class="badge">ADMIN & TUTOR</span>
      <h1>Painel Administrativo</h1>
      <p>Gerencie cursos, alunos, tutores e acompanhe o progresso da plataforma.</p>
    </div>
    <div class="login-right">
      <h2>Acessar Painel</h2>
      <p class="sub">Faça login como administrador ou tutor</p>

      <div class="role-selector">
        <button class="role-btn active" data-role="admin" onclick="selecionarRole('admin')">👑 Administrador</button>
        <button class="role-btn" data-role="tutor" onclick="selecionarRole('tutor')">📚 Tutor</button>
      </div>

      <div class="form-group">
        <label for="email">E-mail</label>
        <input type="email" id="email" placeholder="anderson.boscariol@gmail.com" autocomplete="email" onkeydown="if(event.key==='Enter') fazerLogin()">
      </div>
      <div class="form-group">
        <label for="senha">Senha</label>
        <input type="password" id="senha" placeholder="••••••••" autocomplete="current-password" onkeydown="if(event.key==='Enter') fazerLogin()">
      </div>

      <button id="btn-login" class="btn-login" onclick="fazerLogin()">
        <span class="btn-text">Entrar</span>
        <span class="spinner"></span>
      </button>

      <div id="login-error" class="login-error"></div>

      <div class="login-footer">
        <a href="../login.html">← Voltar para Área do Aluno</a>
      </div>
    </div>
  </div>

  
  <script>
    let selectedRole = 'admin';

    function selecionarRole(role) {
      selectedRole = role;
      document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
      document.querySelector(`.role-btn[data-role="${role}"]`).classList.add('active');
    }

    async function fazerLogin() {
      const email = document.getElementById('email').value.trim();
      const senha = document.getElementById('senha').value;
      const btn = document.getElementById('btn-login');
      const errEl = document.getElementById('login-error');

      errEl.classList.remove('show');
      document.getElementById('email').classList.remove('input-error');
      document.getElementById('senha').classList.remove('input-error');

      if (!email || !senha) {
        if (!email) document.getElementById('email').classList.add('input-error');
        if (!senha) document.getElementById('senha').classList.add('input-error');
        errEl.textContent = 'Preencha e-mail e senha.';
        errEl.classList.add('show');
        return;
      }

      btn.classList.add('loading');
      btn.disabled = true;

      try {
        const loginRes = await fetch(window.location.origin + '/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password: senha })
        });
        const result = await loginRes.json();
        if (!loginRes.ok) throw new Error(result.error || 'Erro ao fazer login');
        
        localStorage.setItem('lms_token', result.token);
        localStorage.setItem('lms_user', JSON.stringify(result.user));

        if (!result || !result.user) {
          throw new Error('Usuário não encontrado');
        }

        const user = result.user;
        
        // Role check — if selectedRole doesn't match user's papel, deny
        if (selectedRole === 'admin' && user.papel !== 'admin') {
          throw new Error('Este usuário não tem permissão de Administrador.');
        }
        if (selectedRole === 'tutor' && user.papel !== 'tutor') {
          throw new Error('Este usuário não tem permissão de Tutor.');
        }

        // Redirect based on papel
        if (user.papel === 'admin') {
          window.location.href = 'index.html';
        } else if (user.papel === 'tutor') {
          window.location.href = '/tutor/index.html';
        } else if (user.papel === 'aluno') {
          window.location.href = '/aluno.html';
        } else {
          window.location.href = 'index.html';
        }
      } catch(e) {
        errEl.textContent = e.message || 'E-mail ou senha incorretos.';
        errEl.classList.add('show');
        document.getElementById('senha').classList.add('input-error');
        btn.classList.remove('loading');
        btn.disabled = false;
      }
    }
  </script>
  <script src="/js/juju-chat.js"></script>
</body>
</html>
