<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Área do Aluno · Instituto Lumethos</title>
  <link rel="icon" href="../img/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    /* ── Lumethos Brand Palette ── */
    :root {
      --bg-cream: #F5F0E8;
      --bg-white: #FAF8F5;
      --bg-card: rgba(255,255,255,0.78);
      --glass-bg: rgba(255,255,255,0.72);
      --glass-border: rgba(199,154,46,0.10);
      --glass-hover: rgba(255,255,255,0.92);
      --gold: #C79A2E;
      --gold-light: #E6C47A;
      --gold-glow: #D4A84B;
      --navy: #0D1B2A;
      --navy-light: #142D4C;
      --navy-dim: rgba(13,27,42,0.55);
      --navy-muted: rgba(13,27,42,0.35);
      --text: #0D1B2A;
      --text-dim: rgba(13,27,42,0.62);
      --text-muted: rgba(13,27,42,0.35);
      --white-soft: #FAF8F5;
      --cream-warm: #EDE6D8;
      --radius: 14px;
      --radius-sm: 10px;
      --sidebar-w: 250px;
      --topbar-h: 56px;
      --glow-gold: 0 0 20px rgba(199,154,46,0.18), 0 0 60px rgba(199,154,46,0.06);
      --glow-card: 0 0 20px rgba(199,154,46,0.08), 0 0 60px rgba(199,154,46,0.03);
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-cream);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ═══════════ ANIMATED GRID BACKGROUND ═══════════ */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        linear-gradient(rgba(199,154,46,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(199,154,46,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 50% at 50% 50%, black 25%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 80% 50% at 50% 50%, black 25%, transparent 70%);
    }

    /* Floating orbs — gold & cream accents */
    .bg-orb {
      position: fixed; border-radius: 50%; pointer-events: none; z-index: 0;
      filter: blur(120px); opacity: 0.10;
      animation: orbFloat 20s ease-in-out infinite;
    }
    .bg-orb.orb-1 {
      width: 600px; height: 600px;
      background: var(--gold);
      top: -200px; right: -150px;
    }
    .bg-orb.orb-2 {
      width: 500px; height: 500px;
      background: var(--gold-light);
      bottom: -200px; left: -100px;
      animation-delay: -10s;
    }
    .bg-orb.orb-3 {
      width: 400px; height: 400px;
      background: var(--navy-light);
      top: 50%; left: 50%;
      animation-delay: -5s;
      opacity: 0.04;
    }

    @keyframes orbFloat {
      0%, 100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(30px, -40px) scale(1.1); }
      50% { transform: translate(-20px, 30px) scale(0.95); }
      75% { transform: translate(-30px, -20px) scale(1.05); }
    }

    /* ═══════════ TOPBAR - GLASS ═══════════ */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: var(--topbar-h);
      background: rgba(2,6,23,0.82);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
    }
    .topbar-left { display: flex; align-items: center; gap: 12px; }
    .topbar-logo { height: 64px; width: auto; filter: brightness(1.1); }
    .topbar-right { display: flex; align-items: center; gap: 14px; }
    .topbar-user-name {
      font-size: 12.5px; color: var(--text-dim); font-weight: 500;
      font-family: 'JetBrains Mono', monospace; font-size: 11px;
      letter-spacing: 0.5px;
    }
    .topbar-avatar {
      width: 34px; height: 34px; border-radius: 10px;
      background: linear-gradient(135deg, var(--purple), var(--cyan));
      color: #fff; display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 14px;
      box-shadow: 0 0 20px rgba(168,85,247,0.25);
      border: 1px solid rgba(255,255,255,0.1);
      cursor: pointer; transition: all 0.3s ease;
    }
    .topbar-avatar:hover {
      box-shadow: 0 0 30px rgba(168,85,247,0.45);
      transform: scale(1.05);
    }
    .topbar-status {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--emerald); margin-right: 6px;
      box-shadow: 0 0 8px var(--emerald-neon);
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .topbar-btn {
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      color: var(--text-dim); padding: 6px 14px; border-radius: 8px;
      font-size: 11px; cursor: pointer; transition: all 0.3s ease;
      font-family: 'Inter', sans-serif; font-weight: 500;
      letter-spacing: 0.3px;
    }
    .topbar-btn:hover {
      color: var(--rose-neon); border-color: rgba(244,63,94,0.3);
      background: rgba(244,63,94,0.08);
      box-shadow: 0 0 15px rgba(244,63,94,0.1);
    }

    /* ═══════════ LAYOUT ═══════════ */
    .layout { display: flex; padding-top: var(--topbar-h); min-height: 100vh; position: relative; z-index: 1; }

    /* ═══════════ SIDEBAR - GLASS ═══════════ */
    .sidebar {
      width: var(--sidebar-w); min-width: var(--sidebar-w);
      background: rgba(15,23,42,0.5);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-right: 1px solid rgba(255,255,255,0.04);
      position: fixed; top: var(--topbar-h); left: 0; bottom: 0;
      overflow-y: auto; z-index: 100;
      padding: 20px 0;
      display: flex; flex-direction: column;
    }
    .sidebar-section { padding: 2px 10px; margin-bottom: 16px; }
    .sidebar-section .section-label {
      font-size: 9px; text-transform: uppercase; letter-spacing: 2.5px;
      color: var(--text-muted); padding: 0 16px; margin-bottom: 10px;
      font-weight: 700; font-family: 'JetBrains Mono', monospace;
    }
    .sidebar-link {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 16px; border-radius: 10px;
      color: var(--text-dim); text-decoration: none;
      font-size: 13px; transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
      font-weight: 500; margin-bottom: 2px;
      position: relative;
      border: 1px solid transparent;
    }
    .sidebar-link .icon {
      font-size: 18px; width: 22px; text-align: center; flex-shrink: 0;
      transition: all 0.3s ease; position: relative; z-index: 1;
    }
    .sidebar-link .label { position: relative; z-index: 1; }
    .sidebar-link .badge {
      margin-left: auto; padding: 3px 8px; border-radius: 6px;
      font-size: 9px; font-weight: 700; letter-spacing: 0.5px;
      font-family: 'JetBrains Mono', monospace;
    }

    /* Neon hover per link */
    .sidebar-link:hover .icon { transform: scale(1.2); }
    .sidebar-link:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(255,255,255,0.08);
    }

    .sidebar-link.accent-gold:hover { color: var(--gold-neon); border-color: rgba(234,179,8,0.25); box-shadow: 0 0 30px rgba(234,179,8,0.1), inset 0 0 30px rgba(234,179,8,0.02); }
    .sidebar-link.accent-blue:hover { color: #60a5fa; border-color: rgba(59,130,246,0.25); box-shadow: 0 0 30px rgba(59,130,246,0.1), inset 0 0 30px rgba(59,130,246,0.02); }
    .sidebar-link.accent-cyan:hover { color: var(--cyan-neon); border-color: rgba(6,182,212,0.25); box-shadow: 0 0 30px rgba(6,182,212,0.1), inset 0 0 30px rgba(6,182,212,0.02); }
    .sidebar-link.accent-green:hover { color: var(--emerald-neon); border-color: rgba(16,185,129,0.25); box-shadow: 0 0 30px rgba(16,185,129,0.1), inset 0 0 30px rgba(16,185,129,0.02); }
    .sidebar-link.accent-purple:hover { color: var(--purple-neon); border-color: rgba(168,85,247,0.25); box-shadow: 0 0 30px rgba(168,85,247,0.1), inset 0 0 30px rgba(168,85,247,0.02); }
    .sidebar-link.accent-rose:hover { color: var(--rose-neon); border-color: rgba(244,63,94,0.25); box-shadow: 0 0 30px rgba(244,63,94,0.1), inset 0 0 30px rgba(244,63,94,0.02); }
    .sidebar-link.accent-amber:hover { color: #f59e0b; border-color: rgba(245,158,11,0.25); box-shadow: 0 0 30px rgba(245,158,11,0.1), inset 0 0 30px rgba(245,158,11,0.02); }
    .sidebar-link.accent-teal:hover { color: #2dd4bf; border-color: rgba(45,212,191,0.25); box-shadow: 0 0 30px rgba(45,212,191,0.1), inset 0 0 30px rgba(45,212,191,0.02); }
    .sidebar-link.accent-red:hover { color: var(--rose-neon); border-color: rgba(244,63,94,0.25); box-shadow: 0 0 30px rgba(244,63,94,0.1), inset 0 0 30px rgba(244,63,94,0.02); }

    /* Active */
    .sidebar-link.active {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(168,85,247,0.2);
      color: var(--purple-neon);
      box-shadow: 0 0 20px rgba(168,85,247,0.08), inset 0 0 20px rgba(168,85,247,0.03);
    }
    .sidebar-link.active::before {
      content: ''; position: absolute; left: -1px; top: 12px; bottom: 12px;
      width: 2px; background: linear-gradient(180deg, var(--purple-neon), var(--cyan-neon));
      border-radius: 0 2px 2px 0;
      box-shadow: 0 0 10px var(--purple-neon);
    }
    .sidebar-link.active .badge {
      background: rgba(168,85,247,0.15);
      color: var(--purple-neon);
    }

    .sidebar-spacer { flex: 1; }

    /* ═══════════ MAIN ═══════════ */
    .main-content {
      flex: 1; margin-left: var(--sidebar-w);
      padding: 28px 32px 60px;
      max-width: calc(100% - var(--sidebar-w));
    }

    /* ═══════════ SECTION HEADERS ═══════════ */
    .section-header {
      display: flex; align-items: center; gap: 12px; margin-bottom: 28px;
    }
    .section-header h2 {
      font-size: 24px; font-weight: 700; letter-spacing: -0.3px;
    }
    .section-header .header-line {
      flex: 1; height: 1px;
      background: linear-gradient(90deg, rgba(168,85,247,0.3), transparent);
    }
    .section-header .header-glow {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--purple);
      box-shadow: 0 0 12px var(--purple-neon), 0 0 24px var(--purple);
      animation: pulse 2s infinite;
    }

    /* ═══════════ STAT CARDS ROW ═══════════ */
    .stats-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
      margin-bottom: 32px;
    }
    .stat-card {
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      padding: 22px 24px;
      transition: all 0.3s ease;
      position: relative; overflow: hidden;
    }
    .stat-card::after {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(168,85,247,0.06) 0%, transparent 60%);
      opacity: 0; transition: opacity 0.3s;
    }
    .stat-card:hover::after { opacity: 1; }
    .stat-card:hover {
      border-color: rgba(168,85,247,0.25);
      box-shadow: 0 0 30px rgba(168,85,247,0.08);
      transform: translateY(-2px);
    }
    .stat-card .stat-icon {
      font-size: 28px; margin-bottom: 12px; display: block;
    }
    .stat-card .stat-value {
      font-size: 28px; font-weight: 800; background: linear-gradient(135deg, var(--text), var(--text-dim));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-card .stat-label {
      font-size: 11px; color: var(--text-muted); font-family: 'JetBrains Mono', monospace;
      text-transform: uppercase; letter-spacing: 1px; margin-top: 4px;
    }

    /* ═══════════ HERO PANEL ═══════════ */
    .hero-panel {
      background: var(--glass-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(168,85,247,0.12);
      border-radius: var(--radius);
      padding: 36px 40px;
      margin-bottom: 32px;
      display: flex; align-items: center; gap: 32px;
      position: relative; overflow: hidden;
    }
    .hero-panel::before {
      content: ''; position: absolute; top: -50%; right: -10%;
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(168,85,247,0.08) 0%, transparent 70%);
      border-radius: 50%;
    }
    .hero-panel::after {
      content: ''; position: absolute; bottom: -30%; left: 20%;
      width: 200px; height: 200px;
      background: radial-gradient(circle, rgba(6,182,212,0.05) 0%, transparent 70%);
      border-radius: 50%;
    }
    .hero-ring { position: relative; z-index: 1; flex-shrink: 0; }
    .hero-ring svg { transform: rotate(-90deg); }
    .hero-ring .ring-text {
      position: absolute; inset: 0; display: flex;
      align-items: center; justify-content: center;
      font-size: 18px; font-weight: 800;
      background: linear-gradient(135deg, var(--gold-neon), var(--purple-neon));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-info { position: relative; z-index: 1; flex: 1; }
    .hero-info .hero-greeting {
      font-size: 12px; text-transform: uppercase; letter-spacing: 3px;
      color: var(--cyan-neon); margin-bottom: 8px;
      font-family: 'JetBrains Mono', monospace; font-weight: 700;
      text-shadow: 0 0 10px rgba(6,182,212,0.3);
    }
    .hero-info h1 {
      font-size: 30px; font-weight: 800; margin-bottom: 10px;
      background: linear-gradient(135deg, var(--text) 0%, var(--text-dim) 50%, var(--purple-neon) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; letter-spacing: -0.5px;
    }
    .hero-info .hero-sub {
      font-size: 13.5px; color: var(--text-dim); line-height: 1.6;
      margin-bottom: 18px; max-width: 420px;
    }
    .hero-actions { display: flex; gap: 12px; position: relative; z-index: 1; }
    .btn-neon {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 11px 26px; border-radius: 10px;
      font-weight: 700; font-size: 13px; cursor: pointer;
      text-decoration: none; transition: all 0.3s ease;
      font-family: 'Inter', sans-serif; border: none;
    }
    .btn-neon.primary {
      background: linear-gradient(135deg, var(--purple), #7c3aed);
      color: #fff;
      box-shadow: 0 0 20px rgba(168,85,247,0.3), 0 4px 12px rgba(0,0,0,0.3);
    }
    .btn-neon.primary:hover {
      box-shadow: 0 0 40px rgba(168,85,247,0.5), 0 8px 24px rgba(0,0,0,0.4);
      transform: translateY(-2px);
    }
    .btn-neon.secondary {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      color: var(--text-dim);
    }
    .btn-neon.secondary:hover {
      border-color: rgba(6,182,212,0.4);
      color: var(--cyan-neon);
      box-shadow: 0 0 20px rgba(6,182,212,0.1);
    }

    /* ═══════════ NETFLIX-STYLE ROWS ═══════════ */
    .content-row { margin-bottom: 40px; }
    .row-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 16px;
    }
    .row-title {
      font-size: 17px; font-weight: 700; color: var(--text);
      display: flex; align-items: center; gap: 10px;
    }
    .row-title .row-accent {
      width: 4px; height: 18px; border-radius: 2px;
      display: inline-block;
    }
    .row-title .row-accent.gold { background: var(--gold); box-shadow: 0 0 10px var(--gold-neon); }
    .row-title .row-accent.cyan { background: var(--cyan); box-shadow: 0 0 10px var(--cyan-neon); }
    .row-title .row-accent.emerald { background: var(--emerald); box-shadow: 0 0 10px var(--emerald-neon); }
    .row-scroll {
      display: flex; gap: 16px; overflow-x: auto;
      padding: 4px 2px 16px;
      scroll-behavior: smooth;
      -ms-overflow-style: none; scrollbar-width: none;
    }
    .row-scroll::-webkit-scrollbar { display: none; }

    /* ═══════════ COURSE CARD - GLASS ═══════════ */
    .course-card {
      min-width: 270px; max-width: 270px;
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: var(--radius);
      overflow: hidden; transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
      flex-shrink: 0; cursor: pointer; text-decoration: none; color: inherit;
      position: relative;
    }
    .course-card::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(168,85,247,0.05), transparent, rgba(6,182,212,0.05));
      opacity: 0; transition: opacity 0.4s;
      border-radius: var(--radius); z-index: 0;
    }
    .course-card:hover::before { opacity: 1; }
    .course-card:hover {
      transform: translateY(-8px);
      border-color: rgba(168,85,247,0.3);
      box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(168,85,247,0.15), 0 0 40px rgba(168,85,247,0.08);
    }
    .course-card .card-thumb {
      height: 150px; position: relative; overflow: hidden;
      background: linear-gradient(135deg, rgba(15,23,42,0.8) 0%, rgba(2,6,23,0.9) 100%);
      display: flex; align-items: center; justify-content: center;
    }
    .course-card .card-thumb-img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.6s ease;
    }
    .course-card:hover .card-thumb-img { transform: scale(1.12); }
    .course-card .card-thumb-icon {
      font-size: 50px; position: absolute; transition: all 0.4s ease;
    }
    .course-card:hover .card-thumb-icon {
      transform: scale(1.2) rotate(3deg);
      opacity: 0.5;
    }
    .course-card .card-badge {
      position: absolute; top: 12px; right: 12px;
      font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 6px;
      font-family: 'JetBrains Mono', monospace; letter-spacing: 0.5px;
      z-index: 2;
    }
    .course-card .card-badge.progress {
      background: rgba(234,179,8,0.12); color: var(--gold-neon);
      border: 1px solid rgba(234,179,8,0.25);
    }
    .course-card .card-badge.new {
      background: rgba(6,182,212,0.12); color: var(--cyan-neon);
      border: 1px solid rgba(6,182,212,0.25);
    }
    .course-card .card-badge.done {
      background: rgba(16,185,129,0.12); color: var(--emerald-neon);
      border: 1px solid rgba(16,185,129,0.25);
    }
    .course-card .card-play-btn {
      position: absolute; inset: 0; display: flex;
      align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.3s ease; z-index: 3;
    }
    .course-card .card-play-circle {
      width: 52px; height: 52px; border-radius: 14px;
      background: linear-gradient(135deg, var(--purple), #7c3aed);
      color: #fff; display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.6), 0 0 30px rgba(168,85,247,0.3);
      transform: scale(0.7); transition: transform 0.3s ease;
    }
    .course-card:hover .card-play-btn { opacity: 1; }
    .course-card:hover .card-play-circle { transform: scale(1); }
    .course-card .card-body { padding: 18px 20px; position: relative; z-index: 1; }
    .course-card .card-body h4 {
      font-size: 14.5px; font-weight: 700; margin-bottom: 6px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .course-card .card-body .card-meta {
      font-size: 11px; color: var(--text-muted);
      font-family: 'JetBrains Mono', monospace;
    }
    .course-card .card-glow-bar {
      height: 2px; margin: 0 20px; border-radius: 1px;
      background: rgba(255,255,255,0.04); overflow: hidden;
    }
    .course-card .card-glow-bar .fill {
      height: 100%; border-radius: 1px;
      background: linear-gradient(90deg, var(--purple), var(--cyan));
      box-shadow: 0 0 10px var(--purple-neon);
      transition: width 0.8s ease;
    }

    /* ═══════════ EMPTY STATE ═══════════ */
    .empty-state {
      text-align: center; padding: 80px 20px;
      background: var(--glass-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
    }
    .empty-state .empty-glow {
      width: 80px; height: 80px; border-radius: 20px;
      background: linear-gradient(135deg, rgba(168,85,247,0.1), rgba(6,182,212,0.1));
      border: 1px solid rgba(168,85,247,0.15);
      display: flex; align-items: center; justify-content: center;
      font-size: 36px; margin: 0 auto 20px;
    }
    .empty-state h3 {
      font-size: 22px; font-weight: 700; margin-bottom: 10px;
      background: linear-gradient(135deg, var(--text), var(--purple-neon));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .empty-state p {
      color: var(--text-dim); font-size: 14px; margin-bottom: 24px;
      max-width: 400px; margin-left: auto; margin-right: auto;
    }

    /* ═══════════ ANIMATIONS ═══════════ */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .anim-in { animation: fadeInUp 0.5s ease forwards; opacity: 0; }
    .anim-d1 { animation-delay: 0.04s; }
    .anim-d2 { animation-delay: 0.1s; }
    .anim-d3 { animation-delay: 0.16s; }
    .anim-d4 { animation-delay: 0.22s; }
    .anim-d5 { animation-delay: 0.28s; }

    /* Loading skeleton */
    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    .skeleton {
      background: linear-gradient(90deg, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.06) 50%, rgba(255,255,255,0.03) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }

    /* ═══════════ RESPONSIVE ═══════════ */
    @media(max-width:1024px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media(max-width:768px) {
      .sidebar { width: 100%; min-width: 100%; position: relative; top: auto; bottom: auto; height: auto; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.04); padding: 6px 0; flex-direction: row; overflow-x: auto; }
      .sidebar-section { padding: 0 3px; margin: 0; display: flex; }
      .sidebar-section .section-label { display: none; }
      .sidebar-link { white-space: nowrap; font-size: 10px; padding: 6px 8px; margin: 0 1px; border-radius: 6px; }
      .sidebar-link .icon { font-size: 13px; width: auto; }
      .sidebar-link .badge { display: none; }
      .sidebar-link.active::before { display: none; }
      .layout { flex-direction: column; }
      .main-content { margin-left: 0; max-width: 100%; padding: 16px 12px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      .stat-card { padding: 16px; }
      .stat-card .stat-value { font-size: 22px; }
      .hero-panel { flex-direction: column; text-align: center; padding: 24px 16px; }
      .hero-info h1 { font-size: 22px; }
      .hero-actions { justify-content: center; }
      .course-card { min-width: 200px; max-width: 200px; }
      .course-card .card-thumb { height: 110px; }
      .topbar-user-name { display: none; }
    }
  </style>
</head>
<body>

<!-- Floating orbs -->
<div class="bg-orb orb-1"></div>
<div class="bg-orb orb-2"></div>
<div class="bg-orb orb-3"></div>

<!-- ═══════════ TOPBAR ═══════════ -->
<nav class="topbar">
  <div class="topbar-left">
    <img src="../img/logo-lumethos-correto.png" alt="Instituto Lumethos" class="topbar-logo" onerror="this.style.display='none'">
  </div>
  <div class="topbar-right">
    <span class="topbar-status"></span>
    <span class="topbar-user-name" id="userName">// carregando...</span>
    <div class="topbar-avatar" id="userAvatar">?</div>
    <button class="topbar-btn" onclick="logout()">LOGOUT</button>
  </div>
</nav>

<!-- ═══════════ LAYOUT ═══════════ -->
<div class="layout">

  <!-- ═══════════ SIDEBAR ═══════════ -->
  <aside class="sidebar">
    <div class="sidebar-section">
      <div class="section-label">● Navegação</div>
      <a href="/aluno/dashboard.html" class="sidebar-link active accent-purple">
        <span class="icon">◆</span><span class="label">Dashboard</span>
      </a>

      <a href="#" class="sidebar-link accent-amber">
        <span class="icon">⬢</span><span class="label">Certificados</span>
        <span class="badge">EM BREVE</span>
      </a>
    </div>

    <div class="sidebar-section">
      <div class="section-label">● Ferramentas</div>
      <a href="/scriba.html" class="sidebar-link accent-teal">
        <span class="icon">◈</span><span class="label">Scriba</span>
        <span class="badge">BETA</span>
      </a>
      <a href="/centelhaz.html" class="sidebar-link accent-purple">
        <span class="icon">✦</span><span class="label">Centelhaz</span>
      </a>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-section">
      <div class="section-label">● Conta</div>
      <a href="/aluno/perfil.html" class="sidebar-link accent-rose">
        <span class="icon">◉</span><span class="label">Meu Perfil</span>
      </a>
      <a href="#" onclick="logout()" class="sidebar-link accent-red">
        <span class="icon">⊘</span><span class="label">Sair</span>
      </a>
    </div>
  </aside>

  <!-- ═══════════ MAIN ═══════════ -->
  <main class="main-content" id="mainContent">
    <div style="display:flex;align-items:center;justify-content:center;min-height:60vh;">
      <div style="text-align:center;color:var(--text-muted);">
        <div class="skeleton" style="width:48px;height:48px;border-radius:14px;margin:0 auto 16px;"></div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:12px;">LOADING...</div>
      </div>
    </div>
  </main>
</div>

<script>
  const API = '/api';
  const TOKEN = localStorage.getItem('lumethos_token');
  const headers = () => ({ 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + TOKEN });

  async function checkAuth() {
    if (!TOKEN) { goLogin(); return null; }
    try {
      const r = await fetch(API + '/auth/me', { headers: headers() });
      if (!r.ok) { localStorage.clear(); goLogin(); return null; }
      return await r.json();
    } catch (e) { localStorage.clear(); goLogin(); return null; }
  }

  function goLogin() { window.location.href = '/login.html?redirect=' + encodeURIComponent(location.pathname + location.search); }
  function logout() { localStorage.clear(); window.location.href = '/login.html'; }

  function ringSVG(pct, sz = 110) {
    const r = 42, circ = 2 * Math.PI * r, offset = circ - (pct/100) * circ;
    return `<svg width="${sz}" height="${sz}" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="${r}" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="5"/>
      <defs><linearGradient id="rg" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#a855f7"/><stop offset="100%" stop-color="#06b6d4"/>
      </linearGradient></defs>
      <circle cx="50" cy="50" r="${r}" fill="none" stroke="url(#rg)" stroke-width="5"
        stroke-dasharray="${circ}" stroke-dashoffset="${offset}" stroke-linecap="round"
        style="filter:drop-shadow(0 0 6px rgba(168,85,247,0.4))"/>
    </svg>`;
  }

  const courseIcons = {
    capelania: '⛪', teologia: '📖', pastoral: '🕊️', infantil: '🧒',
    jovens: '🔥', diaconal: '🤲', hinologia: '🎵', patristica: '🏛️',
    'historia-igreja': '📜'
  };
  function getIcon(slug) { return courseIcons[slug] || '◆'; }

  async function loadDashboard() {
    const authData = await checkAuth();
    if (!authData || !authData.user) return;

    const user = authData.user;
    const nameFallback = (user.email || '').split('@')[0] || 'Aluno';

    let profile = null;
    try { const r = await fetch(API + '/profile', { headers: headers() }); if (r.ok) profile = await r.json(); } catch(e) {}
    const displayName = profile?.name || nameFallback;
    document.getElementById('userName').textContent = '// ' + displayName.toLowerCase();
    document.getElementById('userAvatar').textContent = displayName.charAt(0).toUpperCase();

    // Fetch all courses + user progress, then merge
    let enrollments = [];
    try {
      const [coursesRes, progressRes] = await Promise.all([
        fetch(API + '/courses', { headers: headers() }),
        fetch(API + '/courses/progress', { headers: headers() })
      ]);
      const courses = coursesRes.ok ? await coursesRes.json() : [];
      const progress = progressRes.ok ? await progressRes.json() : [];

      // Build course map from progress: course_id → { completed, total }
      const courseMap = {};
      for (const p of progress) {
        if (!courseMap[p.course_id]) courseMap[p.course_id] = { completed: 0, total: 0 };
        courseMap[p.course_id].total++;
        if (p.completed) courseMap[p.course_id].completed++;
      }

      // Merge with course data (only courses that have progress = enrolled)
      for (const c of courses) {
        const stats = courseMap[c.id];
        if (!stats) continue; // skip if no progress
        const totalLessons = stats.total;
        const pct = totalLessons > 0 ? Math.round((stats.completed / totalLessons) * 100) : 0;
        // Count modules with progress
        const moduleSet = new Set();
        for (const p of progress) {
          if (p.course_id === c.id) moduleSet.add(p.lesson_id);
        }
        enrollments.push({
          id: c.id, slug: c.slug, title: c.title,
          image_url: c.image || '', color: c.color || '#151f38',
          progress_pct: pct,
          modules_completed: stats.completed,
          total_modules: totalLessons
        });
      }
    } catch(e) { console.error('Erro ao carregar cursos:', e); }

    const main = document.getElementById('mainContent');
    let html = '';

    /* ── Stats Grid ── */
    html += `<div class="stats-grid anim-in anim-d1">
      <div class="stat-card"><span class="stat-icon">◆</span><div class="stat-value">${enrollments.length}</div><div class="stat-label">Cursos ativos</div></div>
      <div class="stat-card"><span class="stat-icon">◇</span><div class="stat-value">${totalModules}</div><div class="stat-label">Módulos concluídos</div></div>
      <div class="stat-card"><span class="stat-icon">⬡</span><div class="stat-value">${completed.length}</div><div class="stat-label">Certificados</div></div>
      <div class="stat-card"><span class="stat-icon">⬢</span><div class="stat-value">${overallPct}%</div><div class="stat-label">Progresso total</div></div>
    </div>`;

    /* ── Hero Panel ── */
    html += `<div class="hero-panel anim-in anim-d2">
      <div class="hero-ring">
        ${currentCourse ? ringSVG(currentCourse.progress_pct, 120) : ringSVG(overallPct, 120)}
        <div class="ring-text">${currentCourse ? currentCourse.progress_pct : overallPct}%</div>
      </div>
      <div class="hero-info">
        <div class="hero-greeting">Bem-vindo de volta</div>
        <h1>${displayName.split(' ')[0]}</h1>
        <div class="hero-sub">${currentCourse
          ? `<span style="color:var(--cyan-neon)">${currentCourse.title}</span> · ${currentCourse.modules_completed}/${currentCourse.total_modules} módulos · Continue de onde parou`
          : 'Explore sua biblioteca de formações ministeriais e comece sua jornada.'}</div>
        <div class="hero-actions">
          ${currentCourse ? `<a href="/aluno/curso.html?slug=${currentCourse.slug}" class="btn-neon primary">▶ Continuar</a>` : ''}
          <a href="/aluno/biblioteca.html" class="btn-neon secondary">Biblioteca →</a>
        </div>
      </div>
    </div>`;

    if (enrollments.length === 0) {
      html += `<div class="empty-state anim-in anim-d3">
        <div class="empty-glow">◆</div>
        <h3>Sua jornada começa aqui</h3>
        <p>Explore nossa biblioteca de formações ministeriais e matricule-se no seu primeiro curso.</p>
        <a href="/#cursos" class="btn-neon primary">Explorar Cursos →</a>
      </div>`;
    }

    /* ── Continue Watching ── */
    if (inProgress.length > 0) {
      html += `<div class="content-row anim-in anim-d3" id="cursos">
        <div class="row-header"><div class="row-title"><span class="row-accent gold"></span>Continue Assistindo</div></div>
        <div class="row-scroll">${inProgress.map(c => cardHTML(c, 'progress')).join('')}</div>
      </div>`;
    }

    /* ── Biblioteca ── */
    if (notStarted.length > 0) {
      html += `<div class="content-row anim-in anim-d4" id="biblioteca">
        <div class="row-header"><div class="row-title"><span class="row-accent cyan"></span>Minha Biblioteca</div></div>
        <div class="row-scroll">${notStarted.map(c => cardHTML(c, 'new')).join('')}</div>
      </div>`;
    }

    /* ── Completed ── */
    if (completed.length > 0) {
      html += `<div class="content-row anim-in anim-d5">
        <div class="row-header"><div class="row-title"><span class="row-accent emerald"></span>Concluídos</div></div>
        <div class="row-scroll">${completed.map(c => cardHTML(c, 'done')).join('')}</div>
      </div>`;
    }

    main.innerHTML = html;
  }

  function cardHTML(c, badgeType) {
    const badgeLabel = badgeType === 'new' ? 'NEW' : badgeType === 'done' ? '100%' : `${c.progress_pct}%`;
    const hasBar = badgeType === 'progress';
    return `<a href="/aluno/curso.html?slug=${c.slug}" class="course-card">
      <div class="card-thumb">
        ${c.image_url ? `<img src="${c.image_url}" alt="${c.title}" class="card-thumb-img" loading="lazy" onerror="this.style.display='none'">` : ''}
        <span class="card-thumb-icon">${getIcon(c.slug)}</span>
        <span class="card-badge ${badgeType}">${badgeLabel}</span>
        <div class="card-play-btn"><div class="card-play-circle">${badgeType === 'done' ? '↻' : '▶'}</div></div>
      </div>
      <div class="card-body">
        <h4>${c.title}</h4>
        <div class="card-meta">${c.modules_completed}/${c.total_modules} modules</div>
      </div>
      ${hasBar ? `<div class="card-glow-bar"><div class="fill" style="width:${c.progress_pct}%"></div></div>` : ''}
    </a>`;
  }

  loadDashboard();
</script>
</body>
</html>
