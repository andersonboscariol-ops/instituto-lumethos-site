<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meu Perfil · Instituto Lumethos</title>
  <link rel="icon" href="../img/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    :root {
      --bg-deep: #080e1a; --bg-primary: #0b1424;
      --bg-secondary: #101b30; --bg-card: #151f38;
      --bg-card-hover: #1a2745;
      --gold: #C79A2E; --gold-bright: #e0b84c;
      --gold-glow: rgba(199,154,46,0.18); --gold-soft: rgba(199,154,46,0.10);
      --white: #f1f5f9; --text-primary: #e8edf2;
      --text-secondary: rgba(232,237,242,0.68); --text-muted: rgba(232,237,242,0.38);
      --border: rgba(255,255,255,0.05); --border-hover: rgba(255,255,255,0.10);
      --radius: 16px; --radius-sm: 10px; --radius-xs: 8px;
      --sidebar-w: 248px; --topbar-h: 56px;
      --transition: 0.22s cubic-bezier(0.4,0,0.2,1);
      --green: #22c55e; --red: #ef4444; --rose: #f43f5e;
      --blue: #3b82f6; --purple: #8b5cf6;
    }

    body {
      font-family: 'Inter', sans-serif; background: var(--bg-deep);
      color: var(--text-primary); min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ═══════════ TOPBAR ═══════════ */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: var(--topbar-h);
      background: rgba(8,14,26,0.88);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
    }
    .topbar-left { display: flex; align-items: center; gap: 12px; }
    .topbar-logo { height: 64px; width: auto; }
    .topbar-right { display: flex; align-items: center; gap: 16px; }
    .topbar-user-name { font-size: 13px; color: var(--text-secondary); font-weight: 500; }
    .topbar-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), #d4a843);
      color: var(--bg-primary); display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 16px; box-shadow: 0 2px 12px rgba(199,154,46,0.25);
    }
    .topbar-btn {
      background: none; border: 1px solid var(--border-hover);
      color: var(--text-muted); padding: 6px 14px; border-radius: 50px;
      font-size: 12px; cursor: pointer; transition: all var(--transition);
      font-family: 'Inter', sans-serif; font-weight: 500;
    }
    .topbar-btn:hover { color: #f87171; border-color: rgba(248,113,113,0.3); background: rgba(248,113,113,0.06); }

    /* ═══════════ LAYOUT ═══════════ */
    .layout { display: flex; padding-top: var(--topbar-h); min-height: 100vh; }

    /* ═══════════ SIDEBAR ═══════════ */
    .sidebar {
      width: var(--sidebar-w); min-width: var(--sidebar-w);
      background: var(--bg-primary); border-right: 1px solid var(--border);
      position: fixed; top: var(--topbar-h); left: 0; bottom: 0;
      overflow-y: auto; z-index: 100; padding: 16px 0;
      display: flex; flex-direction: column;
    }
    .sidebar-section { padding: 4px 12px; margin-bottom: 6px; }
    .sidebar-section .section-label {
      font-size: 9.5px; text-transform: uppercase; letter-spacing: 1.8px;
      color: var(--text-muted); padding: 0 14px; margin-bottom: 8px; font-weight: 700;
    }
    .sidebar-link {
      display: flex; align-items: center; gap: 12px;
      padding: 11px 14px; border-radius: var(--radius-xs);
      color: var(--text-secondary); text-decoration: none;
      font-size: 13.5px; transition: all var(--transition); font-weight: 500;
      margin-bottom: 2px; position: relative; overflow: hidden;
    }
    .sidebar-link::before {
      content: ''; position: absolute; inset: 0;
      background: var(--accent, transparent);
      opacity: 0; transition: opacity var(--transition);
      border-radius: var(--radius-xs);
    }
    .sidebar-link:hover::before { opacity: 0.12; }
    .sidebar-link:hover { color: var(--white); }
    .sidebar-link .icon { font-size: 17px; width: 22px; text-align: center; flex-shrink: 0; transition: transform var(--transition); position: relative; z-index: 1; }
    .sidebar-link:hover .icon { transform: scale(1.15); }
    .sidebar-link .label { position: relative; z-index: 1; }
    .sidebar-link .badge {
      margin-left: auto; background: var(--accent-bg, rgba(255,255,255,0.06));
      color: var(--accent-color, var(--text-muted));
      font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 10px;
      position: relative; z-index: 1;
    }
    .sidebar-link.active {
      background: var(--accent-bg, var(--gold-soft));
      color: var(--accent-color, var(--gold)); font-weight: 600;
    }
    .sidebar-link.active::after {
      content: ''; position: absolute; left: 0; top: 6px; bottom: 6px;
      width: 3px; background: var(--accent-color, var(--gold));
      border-radius: 0 3px 3px 0;
    }
    .sidebar-link.accent-gold   { --accent: #C79A2E; --accent-color: #e0b84c; --accent-bg: rgba(199,154,46,0.12); }
    .sidebar-link.accent-blue   { --accent: #3b82f6; --accent-color: #60a5fa; --accent-bg: rgba(59,130,246,0.12); }
    .sidebar-link.accent-cyan   { --accent: #06b6d4; --accent-color: #22d3ee; --accent-bg: rgba(6,182,212,0.12); }
    .sidebar-link.accent-green  { --accent: #22c55e; --accent-color: #4ade80; --accent-bg: rgba(34,197,94,0.12); }
    .sidebar-link.accent-purple { --accent: #8b5cf6; --accent-color: #a78bfa; --accent-bg: rgba(139,92,246,0.12); }
    .sidebar-link.accent-rose   { --accent: #f43f5e; --accent-color: #fb7185; --accent-bg: rgba(244,63,94,0.12); }
    .sidebar-link.accent-amber  { --accent: #f59e0b; --accent-color: #fbbf24; --accent-bg: rgba(245,158,11,0.12); }
    .sidebar-link.accent-teal   { --accent: #14b8a6; --accent-color: #2dd4bf; --accent-bg: rgba(20,184,166,0.12); }
    .sidebar-link.accent-red    { --accent: #ef4444; --accent-color: #f87171; --accent-bg: rgba(239,68,68,0.12); }
    .sidebar-spacer { flex: 1; }

    /* ═══════════ MAIN ═══════════ */
    .main-content {
      flex: 1; margin-left: var(--sidebar-w);
      padding: 32px; max-width: calc(100% - var(--sidebar-w));
    }
    .page-title h1 {
      font-family: 'Cinzel', serif; font-size: 28px; margin-bottom: 4px;
    }
    .page-title p { color: var(--text-secondary); font-size: 14px; margin-bottom: 24px; }

    /* Cards */
    .card {
      background: var(--bg-card); border-radius: var(--radius);
      border: 1px solid var(--border); padding: 28px; margin-bottom: 18px;
      transition: border-color var(--transition);
    }
    .card:hover { border-color: var(--border-hover); }
    .card h3 {
      font-size: 13px; font-weight: 600; margin-bottom: 16px;
      color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.6px;
      display: flex; align-items: center; gap: 8px;
    }
    .card h3::before {
      content: ''; width: 4px; height: 14px; border-radius: 2px;
      background: var(--gold); display: inline-block;
    }

    .form-group { margin-bottom: 15px; }
    .form-group label {
      font-size: 12px; font-weight: 500; color: var(--text-muted);
      display: block; margin-bottom: 5px;
    }
    .form-group input, .form-group textarea {
      width: 100%; padding: 11px 14px; background: var(--bg-secondary);
      border: 1px solid var(--border); border-radius: var(--radius-xs);
      color: var(--white); font-size: 14px; font-family: 'Inter', sans-serif;
      outline: none; transition: all var(--transition);
    }
    .form-group input:focus, .form-group textarea:focus {
      border-color: var(--gold); box-shadow: 0 0 0 3px rgba(199,154,46,0.08);
    }
    .form-group input:disabled { opacity: 0.35; cursor: not-allowed; }
    .form-group textarea { min-height: 80px; resize: vertical; }

    .avatar-section { display: flex; align-items: center; gap: 18px; margin-bottom: 20px; }
    .avatar-circle {
      width: 80px; height: 80px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--gold-bright));
      display: flex; align-items: center; justify-content: center;
      font-size: 34px; font-weight: 700; color: var(--bg-primary);
      flex-shrink: 0; box-shadow: 0 4px 20px rgba(199,154,46,0.25);
      transition: transform var(--transition);
    }
    .avatar-circle:hover { transform: scale(1.05); }
    .avatar-info { font-size: 12px; color: var(--text-muted); }
    .avatar-info strong { color: var(--text-primary); font-size: 14px; display: block; margin-bottom: 2px; }

    /* MIRC badge */
    .mirc-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 18px; border-radius: 8px; font-size: 13px; font-weight: 500;
    }
    .mirc-badge.active { background: rgba(34,197,94,0.10); color: #4ade80; border: 1px solid rgba(34,197,94,0.15); }
    .mirc-badge.expired { background: rgba(239,68,68,0.10); color: #f87171; border: 1px solid rgba(239,68,68,0.15); }
    .mirc-badge.pending { background: rgba(199,154,46,0.10); color: var(--gold); border: 1px solid rgba(199,154,46,0.15); }

    /* Buttons */
    .btn-primary {
      padding: 12px 28px; background: var(--gold); color: #0a1420;
      border: none; border-radius: 50px; font-weight: 700; font-size: 14px;
      cursor: pointer; font-family: 'Inter', sans-serif;
      transition: all var(--transition); box-shadow: 0 2px 12px rgba(199,154,46,0.2);
    }
    .btn-primary:hover {
      background: var(--gold-bright); transform: translateY(-1px);
      box-shadow: 0 6px 24px rgba(199,154,46,0.35);
    }
    .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

    .btn-outline {
      padding: 10px 22px; background: transparent; color: var(--text-secondary);
      border: 1px solid var(--border-hover); border-radius: 50px; font-size: 13px;
      cursor: pointer; font-family: 'Inter', sans-serif;
      transition: all var(--transition); text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

    /* Pills */
    .stats-row { display: flex; gap: 12px; flex-wrap: wrap; }
    .stat-pill {
      padding: 10px 18px; background: var(--gold-soft);
      border: 1px solid rgba(199,154,46,0.15); border-radius: 50px;
      font-size: 12px; color: var(--gold); font-weight: 500;
      transition: all var(--transition);
    }
    .stat-pill:hover { background: var(--gold-glow); border-color: rgba(199,154,46,0.25); }

    /* Toast */
    .toast {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
      padding: 12px 24px; border-radius: 50px; font-size: 13px;
      background: rgba(34,197,94,0.92); color: #fff; z-index: 300;
      opacity: 0; transition: opacity 0.3s; pointer-events: none;
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      font-weight: 500;
    }
    .toast.show { opacity: 1; }
    .toast.error { background: rgba(239,68,68,0.92); }

    /* Info row */
    .info-row {
      display: flex; justify-content: space-between; padding: 5px 0;
      font-size: 13px; border-bottom: 1px solid var(--border);
    }
    .info-row:last-child { border-bottom: none; }
    .info-row .info-key { color: var(--text-muted); }
    .info-row .info-val { font-weight: 500; font-family: monospace; color: var(--text-secondary); }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .anim-in { animation: fadeInUp 0.4s ease forwards; opacity: 0; }
    .anim-d1 { animation-delay: 0.05s; }
    .anim-d2 { animation-delay: 0.12s; }

    @media(max-width:768px) {
      .sidebar { width: 100%; min-width: 100%; position: relative; top: auto; bottom: auto; height: auto; border-right: none; border-bottom: 1px solid var(--border); padding: 8px 0; flex-direction: row; overflow-x: auto; }
      .sidebar-section { padding: 0 6px; margin: 0; }
      .sidebar-section .section-label { display: none; }
      .sidebar-section .sidebar-link { white-space: nowrap; font-size: 11px; padding: 8px 10px; margin: 0 2px; }
      .sidebar-link .icon { font-size: 14px; width: auto; }
      .sidebar-link .badge { display: none; }
      .layout { flex-direction: column; }
      .main-content { margin-left: 0; max-width: 100%; padding: 20px 16px; }
      .topbar-user-name { display: none; }
    }
  </style>
</head>
<body>

<!-- ═══════════ TOPBAR ═══════════ -->
<nav class="topbar">
  <div class="topbar-left">
    <img src="../img/logo-lumethos-correto.png" alt="Instituto Lumethos" class="topbar-logo" onerror="this.style.display='none'">
  </div>
  <div class="topbar-right">
    <span class="topbar-user-name" id="userName">Carregando...</span>
    <div class="topbar-avatar" id="userAvatar">?</div>
    <button class="topbar-btn" onclick="logout()">Sair</button>
  </div>
</nav>

<!-- ═══════════ LAYOUT ═══════════ -->
<div class="layout">

  <!-- ═══════════ SIDEBAR ═══════════ -->
  <aside class="sidebar">
    <div class="sidebar-section">
      <div class="section-label">Navegação</div>
      <a href="/aluno/dashboard.html" class="sidebar-link accent-gold"><span class="icon">⬡</span><span class="label">Dashboard</span></a>

      <a href="#" class="sidebar-link accent-amber"><span class="icon">⬢</span><span class="label">Certificados</span><span class="badge">Em breve</span></a>
    </div>
    <div class="sidebar-section">
      <div class="section-label">Ferramentas</div>
      <a href="/scriba.html" class="sidebar-link accent-teal"><span class="icon">◇</span><span class="label">Scriba</span><span class="badge">Escrever</span></a>
      <a href="/centelhaz.html" class="sidebar-link accent-purple"><span class="icon">✦</span><span class="label">Centelhaz</span><span class="badge">CRM</span></a>
    </div>
    <div class="sidebar-spacer"></div>
    <div class="sidebar-section">
      <div class="section-label">Conta</div>
      <a href="/aluno/perfil.html" class="sidebar-link active accent-rose"><span class="icon">◉</span><span class="label">Meu Perfil</span></a>
      <a href="#" onclick="logout()" class="sidebar-link accent-red"><span class="icon">⊘</span><span class="label">Sair</span></a>
    </div>
  </aside>

  <!-- ═══════════ MAIN ═══════════ -->
  <main class="main-content">
    <div class="page-title anim-in anim-d1">
      <h1>Meu Perfil</h1>
      <p id="pageSub">Carregando...</p>
    </div>
    <div id="profileContent" style="color:var(--text-muted);text-align:center;padding:40px;">Carregando perfil...</div>
  </main>
</div>

<div class="toast" id="toast"></div>

<script>
  const API = '/api';
  function getToken(){ return localStorage.getItem('lumethos_token'); }
  function h(){ return {'Content-Type':'application/json','Authorization':'Bearer '+getToken()}; }
  let profile = null, userData = null;

  async function init() {
    const res = await fetch(API+'/auth/me', { headers: h() });
    if (!res.ok) { window.location.href = '/login.html?redirect=' + encodeURIComponent('/aluno/perfil.html'); return; }
    const data = await res.json();
    userData = data.user || data;

    const displayName = userData.user_metadata?.name || userData.name || userData.email?.split('@')[0] || 'Aluno';
    document.getElementById('userName').textContent = displayName;
    document.getElementById('userAvatar').textContent = displayName.charAt(0).toUpperCase();

    const pfRes = await fetch(API+'/profile', { headers: h() });
    const pf = await pfRes.json();
    profile = pf || { name: userData.user_metadata?.name || userData.name || '', email: userData.email, role: 'aluno' };
    renderProfile();
  }

  function renderProfile() {
    const name = profile.name || userData.email?.split('@')[0] || 'Aluno';
    const initial = name.charAt(0).toUpperCase();
    const mircLabel = profile.mirc_status === 'active' ? '✅ Credencial Ativa' : profile.mirc_status === 'expired' ? '❌ Expirada' : profile.mirc_status ? '⏳ Pendente' : 'Sem credencial';
    const mircClass = profile.mirc_status === 'active' ? 'active' : profile.mirc_status === 'expired' ? 'expired' : 'pending';

    document.getElementById('pageSub').textContent = name;
    document.title = name + ' · Perfil · Lumethos';

    let html = '<div class="card anim-in anim-d2">';
    html += `<div class="avatar-section">
      <div class="avatar-circle">${initial}</div>
      <div class="avatar-info">
        <strong>${name}</strong>
        ${profile.role === 'admin' ? '🔑 Administrador' : profile.role === 'tutor' ? '👨‍🏫 Tutor' : '🎓 Aluno'}
        ${userData.email ? '<br>' + userData.email : ''}
      </div>
    </div>`;

    if (profile.mirc_code) {
      html += `<div class="mirc-badge ${mircClass}" style="margin-bottom:18px;">🛡️ ${profile.mirc_code} · ${mircLabel}</div>`;
    }

    html += `<h3>Informações Pessoais</h3>
      <div class="form-group"><label>Nome</label><input type="text" id="editName" value="${escAttr(profile.name || '')}" placeholder="Seu nome completo"></div>
      <div class="form-group"><label>Telefone (WhatsApp)</label><input type="text" id="editPhone" value="${escAttr(profile.phone || '')}" placeholder="(XX) XXXXX-XXXX"></div>
      <div class="form-group"><label>CPF (para credencial MIRC)</label><input type="text" id="editMatricula" value="${escAttr(profile.matricula || '')}" placeholder="000.000.000-00" ${profile.matricula ? 'disabled' : ''}>${profile.matricula ? '<small style="color:var(--text-muted);font-size:11px;">CPF vinculado — entre em contato para alterar</small>' : ''}</div>
      <div class="form-group"><label>Email</label><input type="email" value="${escAttr(userData.email || '')}" disabled><small style="color:var(--text-muted);font-size:11px;">Gerenciado pelo login</small></div>
      <div style="display:flex;gap:12px;margin-top:20px;flex-wrap:wrap;">
        <button class="btn-primary" onclick="saveProfile()" id="saveBtn">💾 Salvar Alterações</button>
        <a href="/aluno/dashboard.html" class="btn-outline">← Dashboard</a>
      </div>
    </div>`;

    if (profile.mirc_code) {
      html += `<div class="card anim-in anim-d2">
        <h3>Credencial MIRC</h3>
        <div style="padding:8px 0;">
          <div class="info-row"><span class="info-key">Código</span><span class="info-val">${escAttr(profile.mirc_code || '—')}</span></div>
          <div class="info-row"><span class="info-key">Status</span><span class="info-val">${mircLabel}</span></div>
          <div class="info-row"><span class="info-key">Emitida em</span><span class="info-val">${profile.mirc_issued_at ? new Date(profile.mirc_issued_at).toLocaleDateString('pt-BR') : '—'}</span></div>
        </div>
      </div>`;
    }

    if (profile.role === 'aluno' || profile.role === 'tutor') {
      html += `<div class="card anim-in anim-d2">
        <h3>Estatísticas</h3>
        <div class="stats-row">
          <span class="stat-pill" id="statCourses">📚 Carregando...</span>
          <span class="stat-pill" id="statLessons">✅ Carregando...</span>
          <span class="stat-pill" id="statCert">🏅 Carregando...</span>
        </div>
      </div>`;
    }

    document.getElementById('profileContent').innerHTML = html;
    if (profile.role === 'aluno' || profile.role === 'tutor') loadStats();
  }

  async function loadStats() {
    try {
      const r = await fetch(API+'/courses/progress', { headers: h() });
      const d = await r.json();
      const courses = d?.enrollments || d?.courses || [];
      const courseCount = courses.length;
      const lessonCount = courses.reduce((s,c) => s + (c.modules_completed || 0), 0);
      const certCount = courses.filter(c => c.progress_pct >= 100).length;
      document.getElementById('statCourses').textContent = `📚 ${courseCount} cursos`;
      document.getElementById('statLessons').textContent = `✅ ${lessonCount} aulas`;
      document.getElementById('statCert').textContent = `🏅 ${certCount} certificados`;
    } catch(e) {
      document.getElementById('statCourses').textContent = '📚 —';
      document.getElementById('statLessons').textContent = '✅ —';
      document.getElementById('statCert').textContent = '🏅 —';
    }
  }

  async function saveProfile() {
    const btn = document.getElementById('saveBtn');
    btn.disabled = true; btn.textContent = 'Salvando...';
    const updates = {
      name: document.getElementById('editName').value.trim() || null,
      phone: document.getElementById('editPhone').value.trim() || null
    };
    try {
      const r = await fetch(API+'/profile', { method:'PUT', headers:h(), body:JSON.stringify(updates) });
      if (!r.ok) { const e = await r.json().catch(()=>({})); showToast('Erro: ' + (e.message||'Desconhecido'), true); }
      else { showToast('✅ Perfil atualizado!'); profile = {...profile, ...updates}; }
    } catch(e) { showToast('Erro: ' + e.message, true); }
    btn.disabled = false; btn.textContent = '💾 Salvar Alterações';
  }

  function escAttr(s) { if(!s) return ''; return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function showToast(msg, isErr) {
    const t = document.getElementById('toast');
    t.textContent = msg; t.className = 'toast ' + (isErr?'error ':'') + 'show';
    setTimeout(() => t.classList.remove('show'), 3000);
  }
  function logout() { localStorage.clear(); window.location.href = '/login.html'; }

  init();
</script>
</body>
</html>
