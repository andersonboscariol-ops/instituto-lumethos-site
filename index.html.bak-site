                  <svg width="36" height="36" viewBox="0 0 36 36">
                    <rect x="2" y="2" width="12" height="12" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="22" y="2" width="12" height="12" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="2" y="22" width="12" height="12" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="8" y="8" width="3" height="3" fill="currentColor"/>
                    <rect x="25" y="8" width="3" height="3" fill="currentColor"/>
                    <rect x="8" y="25" width="3" height="3" fill="currentColor"/>
                  </svg>
                  <span class="cred-card-qr-label">QR</span>
                </div>
                <div class="cred-card-valid">
                  <span>Válida até</span>
                  <strong>06/2028</strong>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

